# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin
ADMIN_PASSWORD=your-admin-password

# Site
NEXT_PUBLIC_SITE_URL=https://your-domain-here.com

# Access control
RSVP_ACCESS_TYPE=token
RSVP_ACCESS_TOKEN=your-secret-token
RSVP_ACCESS_PASSWORD=your-password

# Email
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=your-email@yourdomain.com

# Grafana Alloy (for docker-compose local dev)
APP_HOST=your-domain-here.com
SCRAPE_SCHEME=https
GRAFANA_PROMETHEUS_URL=https://prometheus-prod-xx-prod-us-west-0.grafana.net
GRAFANA_PROMETHEUS_USER=your-grafana-user-id
GRAFANA_PROMETHEUS_TOKEN=your-grafana-api-token

# Docker Hub (GitHub Actions secrets — not needed locally)
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=your-dockerhub-access-token

# Railway (GitHub Actions secrets — not needed locally)
RAILWAY_TOKEN=your-railway-api-token
RAILWAY_SERVICE_ID=your-railway-service-id
RAILWAY_ENVIRONMENT_ID=your-railway-environment-id
