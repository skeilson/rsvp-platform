# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ CRITICAL: This is the master database key
# Never expose this in logs, errors, or code
# Store securely in Railway/Vercel environment variables only
# Rotate every 90 days
# If exposed, rotate immediately
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin
ADMIN_PASSWORD=your-admin-password
# CRITICAL: Session secret must be 32+ characters of high entropy
# Generate with: openssl rand -hex 32
SESSION_SECRET=generate-a-random-string-here

# Site
APP_HOST=your-domain-here.com
NEXT_PUBLIC_SITE_URL=https://your-domain-here.com

# Access control
SCRAPE_SCHEME=https
RSVP_ACCESS_TYPE=token

# if using token mode, create unique token or use openssl rand -hex 32 to generate
RSVP_ACCESS_TOKEN=your-secret-token

# if using password mode, create unique simple password to share with guests
RSVP_ACCESS_PASSWORD=your-password

# Email
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=your-email@yourdomain.com
RESEND_REPLY_TO_EMAIL=your-actual-email-inbox@email.com

# Grafana Alloy
GRAFANA_PROMETHEUS_URL=your-grafana-prometheus-url
GRAFANA_PROMETHEUS_USER=your-grafana-user-id
GRAFANA_PROMETHEUS_TOKEN=your-grafana-api-token

# Metrics
# Shared secret Alloy / Prometheus must send as Authorization: Bearer <token>
# when scraping /api/metrics. Unset means the endpoint returns 404.
# CRITICAL: Metrics scrape token must be 32+ characters of high entropy
# Generate with: openssl rand -hex 32
METRICS_SCRAPE_TOKEN=generate-a-random-string-here
